   "source": [
    "# Simple Bellman update example\n",
    "\n",
    "gamma = 0.9\n",
    "\n",
    "# current estimate of next state value\n",
    "V_next = 10  \n",
    "\n",
    "# reward received\n",
    "reward = 5  \n",
    "\n",
    "# Bellman update\n",
    "V_current = reward + gamma * V_next\n",
    "\n",
    "print(\"Updated Value:\", V_current)"
   ]
  }
 ],
